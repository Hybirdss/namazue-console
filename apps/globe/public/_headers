/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-XSS-Protection: 0
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob:; connect-src 'self' blob: https://api.namazue.dev https://*.r2.dev https://protomaps.github.io https://plateau.geospatial.jp https://assets.cms.plateau.reearth.io wss://*.aisstream.io https://*.cartocdn.com https://s3.amazonaws.com https://earthquake.usgs.gov; worker-src 'self' blob:; child-src blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Hashed assets — immutable forever (Vite adds content hash)
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# Static data files — cache 1 hour
/data/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Images — cache 1 week
/*.jpg
  Cache-Control: public, max-age=604800

/*.png
  Cache-Control: public, max-age=604800

# PWA manifest — cache 1 day
/manifest.webmanifest
  Cache-Control: public, max-age=86400

# Sitemap/robots — cache 1 hour, allow indexing
/sitemap.xml
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow

/robots.txt
  Cache-Control: public, max-age=86400

# RSS/Atom feed — cache 1 hour
/feed.xml
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow
  Content-Type: application/rss+xml; charset=utf-8

/feed.atom
  Cache-Control: public, max-age=3600
  X-Robots-Tag: index, follow
  Content-Type: application/atom+xml; charset=utf-8

# News sitemap — cache 15 min (news freshness)
/sitemap-news.xml
  Cache-Control: public, max-age=900
  X-Robots-Tag: index, follow

# IndexNow key verification
/b7e4f2a8c1d6e3f9.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# Security policy
/.well-known/security.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# LLM-readable site descriptions (AEO) — cache 1 day
/llms.txt
  Cache-Control: public, max-age=86400
  X-Robots-Tag: index, follow
  Content-Type: text/plain; charset=utf-8

/llms-full.txt
  Cache-Control: public, max-age=86400
  X-Robots-Tag: index, follow
  Content-Type: text/plain; charset=utf-8

# AI plugin manifest
/.well-known/ai-plugin.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

# HTML — short cache, always revalidate for fresh deploys
/index.html
  Cache-Control: public, max-age=300, must-revalidate
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
