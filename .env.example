# ── Globe (Frontend) ──────────────────────────────────────────

# PMTiles vector tiles on R2 — you can use the public URL below or self-host
VITE_PMTILES_URL=https://pub-bf7ee9c3b9f7430496681e94cbfa42cd.r2.dev/namazue.pmtiles

# ── Worker (API) ──────────────────────────────────────────────

# Neon Postgres connection string — https://console.neon.tech
# Create a project, enable PostGIS, copy the pooled connection URL
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# xAI Grok API key — https://console.x.ai
XAI_API_KEY=replace-me

# Internal API token — generate any secure random string (e.g. openssl rand -hex 32)
# Used for authenticated cron/ingest endpoints
INTERNAL_API_TOKEN=replace-me

# AISstream vessel tracking — https://aisstream.io (free registration)
AISSTREAM_API_KEY=replace-me

# ODPT open transport data — https://developer.odpt.org (free, requires Japanese portal registration)
ODPT_CONSUMER_KEY=replace-me
